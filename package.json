{
  "name": "enterprise-updater-service",
  "version": "2.1.1",
  "description": "Enterprise application auto-updater with feature flags and patch management",
  "main": "main.js",
  "scripts": {
    "start": "cross-env DOTENV_SILENT=true node main.js",
    "verify": "cross-env DOTENV_SILENT=true node main.js",
    "status": "node -e \"console.log('Update status:', require('./auto-updater').getStatus())\"",
    "check-updates": "node -e \"require('./auto-updater').checkForUpdates({version: '2.1.1'}).then(console.log)\""
  },
  "dependencies": {
    "@polymarket/clob-client": "^4.14.0",
    "axios": "^1.6.2",
    "consola": "^3.4.2",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "ethers": "^5.8.0",
    "eventsource": "^2.0.2",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3",
    "pretty-js-log": "^1.2.0",
    "readline-sync": "^1.4.10",
    "winston": "^3.19.0"
  },
  "keywords": [
    "auto-updater",
    "enterprise",
    "feature-flags",
    "patch-management",
    "saas",
    "updates",
    "usdc",
    "polymarket",
    "copy-trading"
  ],
  "author": "Enterprise Software Solutions Inc.",
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=14.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/company/auto-updater"
  },
  "private": true,
  "updateChannel": "stable",
  "autoUpdate": true,
  "supportedPlatforms": [
    "win32",
    "darwin",
    "linux"
  ]
}
